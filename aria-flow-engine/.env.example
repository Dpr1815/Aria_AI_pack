PORT=8080
NODE_ENV=development

# MongoDB
DATABASE_URI=mongodb://localhost:27017
DATABASE_NAME=aria_ai

# Authentication

ACCESS_TOKEN_SECRET=jwt-secret-here
REFRESH_TOKEN_SECRET=jwt-secret-here
SESSION_TOKEN_SECRET=jwt-secret-here
SERVICE_TOKEN_SECRET=jwt-secret-here
# OpenAI
OPENAI_API_KEY=sk-openai-api-key
# Google Cloud Storage
GCS_BUCKET_NAME=bucket-name-here
GCS_KEY_FILE_PATH=./credentials/service-account.json
GCS_SIGNED_URL_EXPIRY_SECONDS=604800
GCS_MAX_FILE_SIZE_BYTES=52428800
# Redis (cache / rate-limiting)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true

# Optional: Logging
LOG_LEVEL=info
