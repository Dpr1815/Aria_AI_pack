# Server
PORT=5000
NODE_ENV=development
# HOST=0.0.0.0
# API Flow Engine
API_SERVER_URL=http://localhost:8080
# Database
DATABASE_URI=mongodb://localhost:27017
DATABASE_NAME=aria_ai
# DATABASE_POOL_SIZE=10
# DATABASE_CONNECT_TIMEOUT_MS=10000
# DATABASE_SOCKET_TIMEOUT_MS=45000

# Authentication
SESSION_JWT_SECRET=your-super-secret-jwt-key
SERVICE_TOKEN=service-token
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_MS=60000

# Google Cloud
GCS_KEY_FILE_PATH=./credentials/service-account.json

# Google STT (optional overrides)
# GOOGLE_STT_ENCODING=WEBM_OPUS
# GOOGLE_STT_SAMPLE_RATE=48000
# GOOGLE_STT_LANGUAGE=en-US
# GOOGLE_STT_MODEL=
# GOOGLE_STT_ENHANCED=false

# Google TTS (optional overrides)
# GOOGLE_TTS_ENCODING=LINEAR16
# GOOGLE_TTS_SAMPLE_RATE=24000

# Rhubarb Lip Sync (optional)
RHUBARB_PATH=/usr/local/bin/rhubarb
# LIPSYNC_ENABLED=true
# RHUBARB_TIMEOUT_MS=10000
# RHUBARB_RECOGNIZER=phonetic
# RHUBARB_EXTENDED_SHAPES=false

# WebSocket (optional overrides)
# WS_PATH=/ws
# WS_PING_INTERVAL_MS=30000
# WS_PONG_TIMEOUT_MS=10000
# WS_MAX_MESSAGE_SIZE=1048576

# CORS (comma-separated origins, or * for all)
# CORS_ORIGIN=*

# Redis (cache / rate-limiting)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true

# Retry settings
MAX_RETRY_ATTEMPTS=3

# Optional: Logging
# LOG_LEVEL=info
